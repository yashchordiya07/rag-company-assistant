s# ============================================================
# Private Knowledge AI Assistant - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── LLM Provider ───────────────────────────────────────────
# Options: "openai" | "ollama" | "huggingface"
LLM_PROVIDER=openai

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Ollama (required if LLM_PROVIDER=ollama — runs locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# HuggingFace (required if LLM_PROVIDER=huggingface)
HUGGINGFACE_API_TOKEN=hf-your-token-here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# ─── Embedding Model ────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu          # "cpu" or "cuda"

# ─── Vector Store ───────────────────────────────────────────
VECTOR_STORE_PATH=./data/vector_store
FAISS_INDEX_NAME=company_knowledge

# ─── Chunking ───────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MIN_CHUNK_LENGTH=50

# ─── Retrieval ──────────────────────────────────────────────
TOP_K_RETRIEVAL=10            # Candidates before re-ranking
TOP_K_FINAL=5                 # Final results shown to user
SIMILARITY_THRESHOLD=0.3      # Minimum similarity score

# ─── Re-ranking ─────────────────────────────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ENABLE_RERANKING=true

# ─── Hybrid Search ──────────────────────────────────────────
ENABLE_HYBRID_SEARCH=true
BM25_WEIGHT=0.3
SEMANTIC_WEIGHT=0.7

# ─── Caching (Redis) ────────────────────────────────────────
ENABLE_CACHE=false
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600

# ─── Conversation Memory ────────────────────────────────────
MAX_HISTORY_TURNS=10
ENABLE_QUERY_REWRITING=true

# ─── API Server ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ─── Streamlit UI ───────────────────────────────────────────
UI_PORT=8501
API_BASE_URL=http://localhost:8000

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/rag_system.log

# ─── Upload Limits ──────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,txt,docx,md
